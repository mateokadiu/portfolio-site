---
import Layout from '~/layouts/Layout.astro';
import Hero from '~/components/Hero';
import BentoGrid from '~/components/BentoGrid.astro';
import Tile from '~/components/Tile.astro';
import TileHeader from '~/components/TileHeader.astro';
import { PROJECTS } from '~/lib/data';
---

<Layout>
  <Hero client:idle />

  <BentoGrid id="work">
    {
      PROJECTS.map((project) => (
        <Tile
          size={project.tileSize}
          href={`/projects/${project.slug}`}
          label={`${project.name} — ${project.tagline}`}
          transitionName={`project-${project.slug}`}
        >
          <TileHeader
            name={project.name}
            tagline={project.tagline}
            status={project.status}
            isPrivate={project.isPrivate}
          />
          <div class="mt-4 flex-1 rounded-lg border border-dashed border-border/60 p-3 text-xs text-muted">
            tile demo · placeholder
          </div>
        </Tile>
      ))
    }
  </BentoGrid>
</Layout>
