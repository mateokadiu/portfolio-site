---
import Layout from '~/layouts/Layout.astro';
import Hero from '~/components/Hero';
import BentoGrid from '~/components/BentoGrid.astro';
import Tile from '~/components/Tile.astro';
import TileHeader from '~/components/TileHeader.astro';
import AboutTile from '~/tiles/AboutTile.astro';
import NowTile from '~/tiles/NowTile.astro';
import ContactTile from '~/tiles/ContactTile.astro';
import GithubTile from '~/tiles/GithubTile.astro';
import { PROJECTS } from '~/lib/data';
---

<Layout>
  <Hero client:idle />

  <BentoGrid id="work">
    {
      PROJECTS.map((project) => (
        <Tile
          size={project.tileSize}
          href={`/projects/${project.slug}`}
          label={`${project.name} — ${project.tagline}`}
          transitionName={`project-${project.slug}`}
        >
          <TileHeader
            name={project.name}
            tagline={project.tagline}
            status={project.status}
            isPrivate={project.isPrivate}
          />
          <div class="mt-4 flex-1 rounded-lg border border-dashed border-border/60 p-3 text-xs text-muted">
            tile demo · placeholder
          </div>
        </Tile>
      ))
    }

    <Tile size="1x1"><AboutTile /></Tile>
    <Tile size="1x1"><NowTile /></Tile>
    <Tile size="1x1"><GithubTile /></Tile>
    <Tile size="1x1"><ContactTile /></Tile>
  </BentoGrid>
</Layout>
