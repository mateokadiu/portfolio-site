---
import RolesTimeline from '~/components/cv/RolesTimeline.astro';
import Layout from '~/layouts/Layout.astro';
import {
  type SkillCategory,
  categoryHue,
  categoryLabel,
  loadCertifications,
  loadEducation,
  loadLinks,
  loadPersonal,
  loadRoles,
  loadSkills,
  proficiencyDots,
} from '~/lib/cv';

const [personal, links, skills, roles, education, certifications] = await Promise.all([
  loadPersonal(),
  loadLinks(),
  loadSkills(),
  loadRoles(),
  loadEducation(),
  loadCertifications(),
]);

const categories: SkillCategory[] = [
  'languages',
  'backend',
  'frontend',
  'mobile',
  'data',
  'infra',
  'tools',
];

const SITE = 'https://mateokadiu.pages.dev';
const currentRole = roles[0];

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${SITE}/#person`,
  name: personal.name,
  givenName: personal.name.split(' ')[0],
  familyName: personal.name.split(' ').slice(1).join(' '),
  jobTitle: 'Software Engineer',
  description: personal.tagline,
  email: `mailto:${personal.email}`,
  address: {
    '@type': 'PostalAddress',
    addressLocality: personal.location.split(',')[0]?.trim() ?? 'Tirana',
    addressCountry: 'AL',
  },
  url: SITE,
  mainEntityOfPage: `${SITE}/about`,
  image: `${SITE}/og/about.png`,
  sameAs: [links.github, links.linkedin].filter(Boolean),
  knowsAbout: skills.map((s) => s.name),
  worksFor: currentRole
    ? {
        '@type': 'Organization',
        name: currentRole.company,
        address: {
          '@type': 'PostalAddress',
          addressLocality: currentRole.location.split(',')[0]?.trim(),
        },
      }
    : undefined,
  alumniOf: education.map((e) => ({
    '@type': 'CollegeOrUniversity',
    name: e.school,
    address: { '@type': 'PostalAddress', addressLocality: e.location.split(',')[0]?.trim() },
  })),
  hasOccupation: {
    '@type': 'Occupation',
    name: 'Software Engineer',
    occupationLocation: { '@type': 'City', name: personal.location.split(',')[0]?.trim() },
    skills: skills.map((s) => s.name).join(', '),
  },
};

const profilePageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': `${SITE}/about#profile`,
  url: `${SITE}/about`,
  name: `${personal.name} — About`,
  description: personal.tagline,
  mainEntity: { '@id': `${SITE}/#person` },
  primaryImageOfPage: `${SITE}/og/about.png`,
  inLanguage: 'en-US',
  isPartOf: { '@type': 'WebSite', url: SITE, name: 'Mateo Kadiu' },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE },
    { '@type': 'ListItem', position: 2, name: 'About', item: `${SITE}/about` },
  ],
};
---

<Layout
  title="About"
  description={personal.tagline}
  ogImage="/og/about.png"
  canonical="https://mateokadiu.pages.dev/about"
  pageType="profile"
  jsonLd={[personJsonLd, profilePageJsonLd, breadcrumbJsonLd]}
>
  <article class="mx-auto max-w-5xl px-4 py-10 sm:px-6 sm:py-16">
    <header class="mb-14">
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-muted">
        about · {personal.location} · {personal.timezone}
        {personal.openToWork && <span class="ml-2 text-accent">· open to work</span>}
      </p>
      <h1 class="mt-4 font-mono text-3xl font-semibold tracking-tight sm:text-4xl md:text-5xl">
        {personal.name}
      </h1>
      <p class="mt-3 max-w-2xl text-balance text-base text-muted sm:text-lg">
        {personal.headline}
      </p>
      <p class="mt-4 max-w-2xl text-balance text-sm text-foreground/80">
        {personal.tagline}
      </p>

      <div class="mt-6 flex flex-wrap gap-2 font-mono text-xs">
        {
          links.github && (
            <a
              href={links.github}
              target="_blank"
              rel="noopener"
              class="rounded-md border border-border bg-card px-3 py-1.5 text-muted transition-colors hover:border-accent/40 hover:text-foreground"
            >
              github ↗
            </a>
          )
        }
        {
          links.linkedin && (
            <a
              href={links.linkedin}
              target="_blank"
              rel="noopener"
              class="rounded-md border border-border bg-card px-3 py-1.5 text-muted transition-colors hover:border-accent/40 hover:text-foreground"
            >
              linkedin ↗
            </a>
          )
        }
        <a
          href={`mailto:${personal.email}`}
          class="rounded-md border border-border bg-card px-3 py-1.5 text-muted transition-colors hover:border-accent/40 hover:text-foreground"
        >
          {personal.email} ↗
        </a>
        <a
          href="/Mateo%20Kadiu%20-%20CV.pdf"
          target="_blank"
          rel="noopener"
          class="rounded-md border border-accent/40 bg-accent/10 px-3 py-1.5 text-accent transition-colors hover:bg-accent/15"
        >
          cv.pdf ↗
        </a>
      </div>
    </header>

    {/* SKILLS — typographic matrix, grouped by altitude */}
    <section class="mb-20">
      <header class="mb-5 flex items-baseline justify-between">
        <h2 class="font-mono text-xl font-semibold tracking-tight sm:text-2xl">
          skills<span class="text-accent">.</span>
        </h2>
        <p class="font-mono text-[11px] uppercase tracking-wider text-muted">
          {skills.length} tools
        </p>
      </header>

      <div
        class="grid grid-cols-1 gap-px overflow-hidden rounded-xl border border-border bg-border sm:grid-cols-2 lg:grid-cols-3"
      >
        {
          categories.map((cat) => {
            const inCat = skills
              .filter((s) => s.category === cat)
              .slice()
              .sort((a, b) => b.yearsUsing - a.yearsUsing || a.order - b.order);
            if (inCat.length === 0) return null;
            const hue = categoryHue(cat);
            return (
              <div class="bg-card p-5">
                <div class="mb-3 flex items-baseline justify-between">
                  <h3
                    class="font-mono text-[10px] uppercase tracking-[0.18em]"
                    style={`color: oklch(0.78 0.12 ${hue});`}
                  >
                    {categoryLabel(cat)}
                  </h3>
                  <span class="font-mono text-[10px] text-muted">{inCat.length}</span>
                </div>
                <ul class="space-y-1.5 font-mono text-sm">
                  {inCat.map((s) => {
                    const dots = proficiencyDots(s.proficiency);
                    return (
                      <li class="flex items-center justify-between gap-3">
                        <span class="truncate text-foreground/90">{s.name}</span>
                        <span class="flex shrink-0 items-center gap-2">
                          <span class="text-[11px] tabular-nums text-muted">{s.yearsUsing}y</span>
                          <span class="flex gap-0.5">
                            {Array.from({ length: 4 }).map((_, i) => (
                              <span
                                class="h-[5px] w-[5px] rounded-full"
                                style={`background-color: ${i < dots ? `oklch(0.7 0.16 ${hue})` : 'oklch(0.28 0 0)'};`}
                              />
                            ))}
                          </span>
                        </span>
                      </li>
                    );
                  })}
                </ul>
              </div>
            );
          })
        }
      </div>
    </section>

    {/* EXPERIENCE — sticky-scroll timeline */}
    <section class="mb-20">
      <header class="mb-8">
        <h2 class="font-mono text-xl font-semibold tracking-tight sm:text-2xl">
          experience<span class="text-accent">.</span>
        </h2>
      </header>
      <RolesTimeline roles={roles} />
    </section>

    {/* EDUCATION */}
    {
      education.length > 0 && (
        <section class="mb-16">
          <header class="mb-6">
            <h2 class="font-mono text-xl font-semibold tracking-tight sm:text-2xl">
              education<span class="text-accent">.</span>
            </h2>
          </header>
          <ul class="space-y-4">
            {education.map((e) => (
              <li class="rounded-xl border border-border bg-card p-4">
                <p class="font-mono text-[11px] uppercase tracking-wider text-muted">
                  {e.startYear} — {e.endYear} · {e.location}
                </p>
                <h3 class="mt-1 font-mono text-base font-semibold text-foreground">
                  {e.degree} · <span class="text-muted">{e.school}</span>
                </h3>
                {e.notes && <p class="mt-2 text-sm text-muted">{e.notes}</p>}
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {/* CERTIFICATIONS */}
    {
      certifications.length > 0 && (
        <section class="mb-16">
          <header class="mb-6">
            <h2 class="font-mono text-xl font-semibold tracking-tight sm:text-2xl">
              certs<span class="text-accent">.</span>
            </h2>
          </header>
          <ul class="flex flex-wrap gap-2 font-mono text-xs">
            {certifications.map((c) => (
              <li>
                <a
                  href={c.credentialUrl || '#'}
                  class="rounded-md border border-border bg-card px-3 py-1.5 text-muted transition-colors hover:border-accent/40 hover:text-foreground"
                  target={c.credentialUrl ? '_blank' : undefined}
                  rel="noopener"
                >
                  {c.name} · {c.issuer}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</Layout>
