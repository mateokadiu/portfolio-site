---
import { NOW } from '~/lib/data';
---

<div class="flex h-full flex-col">
  <header class="flex items-start justify-between">
    <h3 class="font-mono text-sm font-medium text-foreground">now</h3>
    <span class="h-2 w-2 animate-pulse rounded-full bg-accent" aria-hidden="true"></span>
  </header>

  <p class="mt-1 text-xs text-muted">currently exploring</p>

  <ul class="mt-3 space-y-1.5 font-mono text-[11px] text-foreground/90">
    {
      NOW.map((line) => (
        <li class="flex items-start gap-2">
          <span class="mt-1.5 inline-block h-1 w-1 rounded-full bg-accent" aria-hidden="true" />
          <span>{line}</span>
        </li>
      ))
    }
  </ul>
</div>
