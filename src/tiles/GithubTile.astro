---
import commits from '~/lib/recent-commits.json';

interface CommitEntry {
  repo: string;
  sha: string;
  message: string;
  date: string | null;
  url: string;
}

const items = (commits as CommitEntry[]).slice(0, 5);

const relative = (iso: string | null) => {
  if (!iso) return '';
  const then = new Date(iso).getTime();
  const now = Date.now();
  const sec = Math.max(0, Math.floor((now - then) / 1000));
  if (sec < 60) return `${sec}s`;
  if (sec < 3600) return `${Math.floor(sec / 60)}m`;
  if (sec < 86400) return `${Math.floor(sec / 3600)}h`;
  if (sec < 86400 * 30) return `${Math.floor(sec / 86400)}d`;
  if (sec < 86400 * 365) return `${Math.floor(sec / (86400 * 30))}mo`;
  return `${Math.floor(sec / (86400 * 365))}y`;
};
---

<div class="flex h-full flex-col">
  <header class="flex items-start justify-between">
    <h3 class="font-mono text-sm font-medium text-foreground">github</h3>
    <span class="font-mono text-[10px] uppercase text-muted">latest</span>
  </header>

  <ul class="mt-3 space-y-2 font-mono text-[11px]">
    {
      items.map((item) => (
        <li class="leading-tight">
          <a
            href={item.url}
            target="_blank"
            rel="noopener"
            class="group flex items-start gap-2 text-foreground/80 transition-colors hover:text-foreground"
          >
            <span class="mt-0.5 inline-block rounded bg-background px-1 py-px font-mono text-[10px] text-accent">
              {item.sha}
            </span>
            <span class="min-w-0 flex-1 truncate">{item.message}</span>
            <span class="shrink-0 text-[11px] text-muted">{relative(item.date)}</span>
          </a>
          <p class="ml-12 text-[11px] text-muted">{item.repo.split('/')[1]}</p>
        </li>
      ))
    }
  </ul>
</div>
