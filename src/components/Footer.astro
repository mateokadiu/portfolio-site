---
import { SITE, SOCIAL } from '~/lib/data';
---

<footer class="border-t border-border/60 px-6 py-10">
  <div
    class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-4 sm:flex-row sm:items-center"
  >
    <p class="font-mono text-xs text-muted">
      © {new Date().getFullYear()} {SITE.author} — MIT licensed
    </p>
    <ul class="flex items-center gap-4 font-mono text-xs">
      <li>
        <a
          href="https://github.com/mateokadiu/portfolio-site"
          target="_blank"
          rel="noopener"
          class="text-muted hover:text-foreground transition-colors">source</a
        >
      </li>
      <li>
        <a
          href={SOCIAL.github}
          target="_blank"
          rel="noopener"
          class="text-muted hover:text-foreground transition-colors">github</a
        >
      </li>
      <li>
        <a
          href={SOCIAL.linkedin}
          target="_blank"
          rel="noopener"
          class="text-muted hover:text-foreground transition-colors">linkedin</a
        >
      </li>
      <li>
        <a
          href={`mailto:${SOCIAL.email}`}
          class="text-muted hover:text-foreground transition-colors">email</a
        >
      </li>
    </ul>
  </div>
</footer>
