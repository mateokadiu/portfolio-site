---
interface Props {
  id?: string;
  className?: string;
}
const { id, className = '' } = Astro.props;
---

<section id={id} class:list={['mx-auto max-w-6xl px-6 pb-24', className]}>
  <header class="mb-8 flex items-baseline justify-between">
    <h2 class="font-display text-2xl font-semibold tracking-tight sm:text-3xl">
      work<span class="text-accent">.</span>
    </h2>
    <p class="font-mono text-xs uppercase tracking-wider text-muted">
      tiles run real code
    </p>
  </header>
  <div class="grid grid-cols-1 gap-4 md:grid-cols-4 md:gap-5 lg:grid-cols-6">
    <slot />
  </div>
</section>
