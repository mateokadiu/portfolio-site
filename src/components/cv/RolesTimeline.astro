---
import type { Role } from '~/lib/cv';

interface Props {
  roles: Role[];
}

const { roles } = Astro.props;

function formatRange(start: string, end: string | null): string {
  const s = new Date(start);
  const e = end ? new Date(end) : null;
  const fmt = (d: Date) =>
    d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' }).toLowerCase();
  return `${fmt(s)} → ${e ? fmt(e) : 'now'}`;
}
---

<div class="relative">
  <div
    class="absolute bottom-0 left-3 top-0 w-px bg-gradient-to-b from-accent/50 via-border to-transparent"
    aria-hidden="true"
  >
  </div>

  <ol class="space-y-10">
    {
      roles.map((r) => (
        <li class="relative pl-10">
          <span
            class:list={[
              'absolute left-1.5 top-1.5 h-3 w-3 rounded-full ring-4 ring-background',
              r.accent === 'orange' && 'bg-accent',
              r.accent === 'cyan' && 'bg-[oklch(0.7_0.16_200)]',
              r.accent === 'lime' && 'bg-[oklch(0.78_0.18_130)]',
            ]}
            aria-hidden="true"
          />
          <header class="mb-2">
            <p class="font-mono text-[11px] uppercase tracking-wider text-muted">
              {formatRange(r.startDate, r.endDate)} · {r.location}
              {r.remote && ' · remote'}
            </p>
            <h3 class="mt-1 font-mono text-xl font-semibold text-foreground">
              {r.title} <span class="text-muted">·</span>{' '}
              <span class="text-accent">{r.company}</span>
            </h3>
            <p class="mt-2 text-sm text-foreground/80">{r.summary}</p>
          </header>
          <ul class="space-y-1.5 text-sm text-muted">
            {r.bullets.map((b) => (
              <li class="flex gap-2 leading-relaxed">
                <span class="select-none font-mono text-accent">▸</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
          {r.stack.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-1.5">
              {r.stack.map((t) => (
                <span class="rounded-md border border-border bg-card px-2 py-0.5 font-mono text-[10px] text-muted">
                  {t}
                </span>
              ))}
            </div>
          )}
        </li>
      ))
    }
  </ol>
</div>
