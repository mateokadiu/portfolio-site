---
import { SOCIAL } from '~/lib/data';
---

<header
  class="sticky top-0 z-50 border-b border-border/60 bg-background/80 backdrop-blur"
  transition:persist
>
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4" aria-label="primary">
    <a
      href="/"
      class="rounded font-mono text-sm font-semibold tracking-tight text-foreground transition-colors hover:text-accent"
    >
      <span class="sr-only">Mateo Kadiu — home</span>
      <span aria-hidden="true">mk<span class="text-accent">.</span></span>
    </a>
    <ul class="flex items-center gap-6 text-sm text-muted">
      <li>
        <a href="/#work" data-anchor class="transition-colors hover:text-foreground">work</a>
      </li>
      <li>
        <a href="/cv" class="transition-colors hover:text-foreground">cv</a>
      </li>
      <li>
        <a
          href={SOCIAL.github}
          class="transition-colors hover:text-foreground"
          rel="noopener"
          target="_blank">github</a
        >
      </li>
      <li>
        <a
          href={`mailto:${SOCIAL.email}`}
          class="hidden font-mono text-foreground transition-colors hover:text-accent sm:inline"
          >say hi</a
        >
      </li>
    </ul>
  </nav>
</header>

<script>
  // Astro view transitions persist the nav across navigations, but the
  // browser's default fragment-scroll doesn't fire when ClientRouter intercepts
  // the link. Hand-roll smooth scroll for in-page anchors.
  function bindAnchors() {
    for (const a of document.querySelectorAll<HTMLAnchorElement>('a[data-anchor]')) {
      a.addEventListener('click', (e) => {
        const href = a.getAttribute('href') ?? '';
        const hashIdx = href.indexOf('#');
        if (hashIdx < 0) return;
        const id = href.slice(hashIdx + 1);
        const target = document.getElementById(id);
        // Only intercept when we're already on the right page (or hash is on root)
        const targetPath = href.slice(0, hashIdx) || '/';
        const onTargetPage = window.location.pathname === targetPath || (targetPath === '/' && window.location.pathname === '/');
        if (target && onTargetPage) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          history.replaceState(null, '', `#${id}`);
        }
        // Otherwise let the navigation happen; the page transition lands at top, then we scroll.
      });
    }
  }
  bindAnchors();
  document.addEventListener('astro:page-load', bindAnchors);
</script>
