---
import { SOCIAL } from '~/lib/data';
---

<header class="sticky top-0 z-50 border-b border-border/60 bg-background/80 backdrop-blur">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a
      href="/"
      class="font-mono text-sm font-semibold tracking-tight text-foreground hover:text-accent transition-colors"
    >
      mk<span class="text-accent">.</span>
    </a>
    <ul class="flex items-center gap-6 text-sm text-muted">
      <li>
        <a href="/#work" class="hover:text-foreground transition-colors">work</a>
      </li>
      <li>
        <a href="/#about" class="hover:text-foreground transition-colors">about</a>
      </li>
      <li>
        <a
          href={SOCIAL.github}
          class="hover:text-foreground transition-colors"
          rel="noopener"
          target="_blank">github</a
        >
      </li>
      <li>
        <a
          href={`mailto:${SOCIAL.email}`}
          class="hidden font-mono text-foreground hover:text-accent transition-colors sm:inline"
          >say hi</a
        >
      </li>
    </ul>
  </nav>
</header>
